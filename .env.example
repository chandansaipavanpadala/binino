# Binino environment configuration template
# Copy this file to .env and adjust variables as needed

# Local Ghidra installation path (required for decompiler backend)
# Windows example: C:\Program Files\ghidra_12.1.2_PUBLIC
# Linux/macOS example: /opt/ghidra_12.1.2_PUBLIC
GHIDRA_HOME=

# Anthropic Claude API Key (optional, required for the AI Explain feature)
ANTHROPIC_API_KEY=

# Allowed CORS origins for the FastAPI server (comma-separated list)
# Defaults to localhost dev configurations if left blank
BININO_ALLOWED_ORIGINS=http://localhost:5173,http://127.0.0.1:5173
